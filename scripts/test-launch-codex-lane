#!/usr/bin/env bash
set -Eeuo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
LAUNCHER=$ROOT/scripts/launch-codex-lane
TMP=$(mktemp -d "${TMPDIR:-/tmp}/agent-fanout-launch-test.XXXXXX")

cleanup() {
  rm -rf "$TMP"
}
trap cleanup EXIT

make_repo() {
  local repo=$1
  mkdir -p "$repo"
  git -C "$repo" init -q
  git -C "$repo" config user.email test@example.invalid
  git -C "$repo" config user.name "Agent Fanout Test"
  printf 'base\n' > "$repo/file.txt"
  git -C "$repo" add file.txt
  git -C "$repo" commit -q -m init
}

make_fake_codex() {
  local fake=$1
  cat > "$fake" <<'FAKE'
#!/usr/bin/env bash
set -Eeuo pipefail

mode=${FAKE_CODEX_MODE:?FAKE_CODEX_MODE is required}
sessions=${CODEX_HOME:?CODEX_HOME is required}/sessions/2026/06/23
mkdir -p "$sessions"
rollout=$sessions/rollout-fake-${mode}.jsonl
cwd=$(pwd)
if [[ -n "${FAKE_CODEX_PID_FILE:-}" ]]; then
  printf '%s\n' "$$" > "$FAKE_CODEX_PID_FILE"
fi

write_started() {
  printf '{"timestamp":"2026-06-23T00:00:00.000Z","type":"session_meta","payload":{"cwd":"%s","originator":"codex_exec"}}\n' "$cwd" > "$rollout"
  printf '{"timestamp":"2026-06-23T00:00:01.000Z","type":"event_msg","payload":{"type":"task_started"}}\n' >> "$rollout"
}

result=
json=0
args=("$@")
for ((i = 0; i < ${#args[@]}; i++)); do
  case "${args[$i]}" in
    --json)
      json=1
      ;;
    -o|--output-last-message)
      i=$((i + 1))
      result=${args[$i]:-}
      ;;
  esac
done

emit_json() {
  if (( json )); then
    printf '%s\n' "$1"
  else
    printf '%s\n' "$1" >&2
  fi
}

case "$mode" in
  dead-start)
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    while :; do sleep 10; done
    ;;
  parent-rollout-false-positive)
    parent=$sessions/rollout-parent-${mode}.jsonl
    printf '{"timestamp":"2026-06-23T00:00:00.000Z","type":"session_meta","payload":{"cwd":"%s","originator":"codex-tui"}}\n' "$cwd/.." > "$parent"
    printf '{"timestamp":"2026-06-23T00:00:01.000Z","type":"response_item","payload":{"type":"function_call","arguments":"launch --worktree %s"}}\n' "$cwd" >> "$parent"
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    while :; do sleep 10; done
    ;;
  json-start)
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    emit_json '{"type":"turn.started"}'
    emit_json '{"type":"item.started","item":{"id":"item_1","type":"command_execution","status":"in_progress"}}'
    emit_json '{"type":"item.completed","item":{"id":"item_1","type":"command_execution","status":"completed"}}'
    ;;
  confirmed-hang)
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    emit_json '{"type":"turn.started"}'
    emit_json '{"type":"item.completed","item":{"id":"item_1","type":"agent_message","text":"started"}}'
    while :; do sleep 10; done
    ;;
  diff-start)
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    printf 'changed\n' >> file.txt
    ;;
  result-start)
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    [[ -n "$result" ]] && printf 'done\n' > "$result"
    ;;
  result-then-hang)
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    emit_json '{"type":"turn.started"}'
    emit_json '{"type":"item.completed","item":{"id":"item_1","type":"agent_message","text":"done"}}'
    [[ -n "$result" ]] && printf 'done\n' > "$result"
    while :; do sleep 10; done
    ;;
  stderr-progress)
    write_started
    emit_json '{"type":"thread.started","thread_id":"fake-thread"}'
    emit_json '{"type":"turn.started"}'
    emit_json '{"type":"item.started","item":{"id":"item_1","type":"command_execution","status":"in_progress"}}'
    for i in 1 2 3; do
      printf 'still running %s\n' "$i" >&2
      sleep 1
    done
    emit_json '{"type":"item.completed","item":{"id":"item_1","type":"command_execution","status":"completed"}}'
    ;;
  early-exit)
    exit 0
    ;;
  *)
    echo "unknown FAKE_CODEX_MODE: $mode" >&2
    exit 64
    ;;
esac
FAKE
  chmod +x "$fake"
}

assert_contains() {
  local file=$1 text=$2
  if ! grep -Fq "$text" "$file"; then
    echo "expected $file to contain: $text" >&2
    exit 1
  fi
}

run_case() {
  local name=$1 mode=$2 expected=$3 expected_result_text=${4:-}
  local case_dir=$TMP/$name repo=$TMP/$name/repo fake=$TMP/$name/fake-codex
  local result=$TMP/$name/result.md run_log=$TMP/$name/run.log brief=$TMP/$name/brief.md
  local pid_file=$TMP/$name/fake.pid
  mkdir -p "$case_dir"
  make_repo "$repo"
  make_fake_codex "$fake"
  printf 'test brief for %s\n' "$name" > "$brief"

  set +e
  CODEX_HOME="$TMP/$name/codex-home" FAKE_CODEX_MODE="$mode" FAKE_CODEX_PID_FILE="$pid_file" \
    "$LAUNCHER" \
      --worktree "$repo" \
      --brief "$brief" \
      --result "$result" \
      --run-log "$run_log" \
      --codex-bin "$fake" \
      --startup-timeout 2 \
      --quiet-timeout 2 \
      --poll-interval 1 \
      > "$TMP/$name/wrapper.out" 2> "$TMP/$name/wrapper.err"
  local status=$?
  set -e

  if [[ "$status" -ne "$expected" ]]; then
    echo "case $name: expected exit $expected, got $status" >&2
    echo "--- stdout ---" >&2
    cat "$TMP/$name/wrapper.out" >&2
    echo "--- stderr ---" >&2
    cat "$TMP/$name/wrapper.err" >&2
    echo "--- result ---" >&2
    [[ -f "$result" ]] && cat "$result" >&2
    exit 1
  fi

  if [[ -n "$expected_result_text" ]]; then
    assert_contains "$result" "$expected_result_text"
  fi

  if [[ "$mode" == "dead-start" && -f "$pid_file" ]]; then
    local fake_pid
    fake_pid=$(<"$pid_file")
    if kill -0 "$fake_pid" 2>/dev/null; then
      echo "case $name: fake codex process still alive after watchdog exit: $fake_pid" >&2
      exit 1
    fi
  fi

  printf 'ok %-18s exit=%s\n' "$name" "$status"
}

wait_for() {  # wait_for <timeout-sec> <cmd...>
  local deadline=$((SECONDS + $1)); shift
  until "$@" 2>/dev/null; do
    (( SECONDS < deadline )) || return 1
    sleep 0.2
  done
}

kill_test_child() {
  local pid=$1 pgid self_pgid
  pgid=$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ')
  self_pgid=$(ps -o pgid= -p $$ | tr -d ' ')
  if [[ "$pgid" =~ ^[0-9]+$ && "$pgid" == "$pid" && "$pgid" != "$self_pgid" ]]; then
    kill -KILL "-$pgid" 2>/dev/null || true
  else
    kill -KILL "$pid" 2>/dev/null || true
  fi
}

# Signal the wrapper mid-run and check the child's fate. Uses SIGTERM because
# backgrounded jobs enter with SIGINT ignored (the launcher traps INT/TERM/HUP
# with one handler, so TERM exercises the same path).
run_signal_case() {
  local name=$1 mode=$2 wait_for_confirm=$3 child_should_survive=$4
  local case_dir=$TMP/$name repo=$TMP/$name/repo fake=$TMP/$name/fake-codex
  local result=$TMP/$name/result.md run_log=$TMP/$name/run.log brief=$TMP/$name/brief.md
  local pid_file=$TMP/$name/fake.pid out=$TMP/$name/wrapper.out err=$TMP/$name/wrapper.err
  mkdir -p "$case_dir"
  make_repo "$repo"
  make_fake_codex "$fake"
  printf 'test brief for %s\n' "$name" > "$brief"

  CODEX_HOME="$TMP/$name/codex-home" FAKE_CODEX_MODE="$mode" FAKE_CODEX_PID_FILE="$pid_file" \
    "$LAUNCHER" \
      --worktree "$repo" \
      --brief "$brief" \
      --result "$result" \
      --run-log "$run_log" \
      --codex-bin "$fake" \
      --startup-timeout 60 \
      --quiet-timeout 60 \
      --poll-interval 1 \
      > "$out" 2> "$err" &
  local wrapper_pid=$!

  if ! wait_for 20 test -s "$pid_file"; then
    echo "case $name: fake codex never started" >&2
    kill -KILL "$wrapper_pid" 2>/dev/null || true
    exit 1
  fi
  if (( wait_for_confirm )) && ! wait_for 20 grep -q "progress confirmed" "$out"; then
    echo "case $name: wrapper never confirmed progress" >&2
    kill -KILL "$wrapper_pid" 2>/dev/null || true
    exit 1
  fi

  kill -TERM "$wrapper_pid"
  set +e
  wait "$wrapper_pid"
  local status=$?
  set -e
  if [[ "$status" -ne 130 ]]; then
    echo "case $name: expected wrapper exit 130, got $status" >&2
    cat "$out" "$err" >&2
    exit 1
  fi

  local fake_pid
  fake_pid=$(<"$pid_file")
  if (( child_should_survive )); then
    if ! kill -0 "$fake_pid" 2>/dev/null; then
      echo "case $name: child was killed but should have been detached" >&2
      cat "$out" "$err" >&2
      exit 1
    fi
    assert_contains "$err" "codex is still running"
    kill_test_child "$fake_pid"
  else
    if kill -0 "$fake_pid" 2>/dev/null; then
      echo "case $name: child survived but should have been killed pre-startup" >&2
      kill_test_child "$fake_pid"
      exit 1
    fi
  fi

  printf 'ok %-18s exit=%s\n' "$name" "$status"
}

run_durable_state_case() {
  local name=$1 mode=$2 action=$3 expected_exit=$4 expected_state=$5
  local case_dir=$TMP/$name
  local repo=$case_dir/repo fake=$case_dir/fake-codex
  local result=$case_dir/result.md run_log=$case_dir/run.log brief=$case_dir/brief.md
  local pid_file=$case_dir/fake.pid state=$case_dir/state out=$case_dir/wrapper.out err=$case_dir/wrapper.err
  mkdir -p "$case_dir"
  make_repo "$repo"
  make_fake_codex "$fake"
  printf 'test brief for %s\n' "$name" > "$brief"

  CODEX_HOME="$case_dir/codex-home" FAKE_CODEX_MODE="$mode" FAKE_CODEX_PID_FILE="$pid_file" \
    "$LAUNCHER" \
      --worktree "$repo" --brief "$brief" --result "$result" --run-log "$run_log" \
      --state-dir "$state" --codex-bin "$fake" --startup-timeout 60 --quiet-timeout 60 \
      --poll-interval 1 > "$out" 2> "$err" &
  local wrapper_pid=$!

  if ! wait_for 20 test -s "$state/child.pid"; then
    echo "case $name: durable child metadata was not published" >&2
    kill -KILL "$wrapper_pid" 2>/dev/null || true
    exit 1
  fi
  assert_contains "$state/worktree" "$(cd "$repo" && pwd -P)"
  if [[ "$action" == cancel ]]; then
    if ! wait_for 20 grep -q "progress confirmed" "$out"; then
      echo "case $name: progress was not confirmed before cancellation" >&2
      kill -KILL "$wrapper_pid" 2>/dev/null || true
      exit 1
    fi
    kill -USR1 "$wrapper_pid"
  fi

  set +e
  wait "$wrapper_pid"
  local status=$?
  set -e
  if [[ "$status" -ne "$expected_exit" ]]; then
    echo "case $name: expected exit $expected_exit, got $status" >&2
    cat "$out" "$err" >&2
    exit 1
  fi
  assert_contains "$state/status" "$expected_state"
  assert_contains "$state/exit-code" "$expected_exit"
  local child_pid
  child_pid=$(<"$state/child.pid")
  if kill -0 "$child_pid" 2>/dev/null; then
    echo "case $name: durable child still alive after terminal state: $child_pid" >&2
    kill_test_child "$child_pid"
    exit 1
  fi
  printf 'ok %-18s exit=%s state=%s\n' "$name" "$status" "$expected_state"
}

bash -n "$LAUNCHER"

run_case dead-start dead-start 124 "no child progress before startup timeout"
run_case parent-rollout-false-positive parent-rollout-false-positive 124 "no child progress before startup timeout"
run_case json-start json-start 0
run_case diff-start diff-start 0
run_case result-start result-start 0
run_case result-then-hang result-then-hang 124 "no child progress for 2s"
run_case stderr-progress stderr-progress 0
run_case early-exit early-exit 1 "codex exited before any child progress signal"
run_signal_case signal-pre-start dead-start 0 0
run_signal_case signal-post-start confirmed-hang 1 1
run_durable_state_case durable-success json-start wait 0 succeeded
run_durable_state_case durable-cancel confirmed-hang cancel 125 cancelled

echo "all launch-codex-lane tests passed"
