#!/usr/bin/env bash
set -Eeuo pipefail

# Re-exec from a private copy: bash reads scripts incrementally, so editing this
# file while an instance is mid-run tears the running interpreter (observed as a
# spurious syntax error while the codex child survives as an orphan). The copy
# is immune to source edits; it removes itself via the existing EXIT trap chain.
if [ -z "${LAUNCH_CODEX_LANE_SELFCOPY:-}" ]; then
  _self_copy=$(mktemp "${TMPDIR:-/tmp}/launch-codex-lane.self.XXXXXX")
  cp "$0" "$_self_copy"
  chmod +x "$_self_copy"
  LAUNCH_CODEX_LANE_SELFCOPY="$_self_copy" exec bash "$_self_copy" "$@"
fi

usage() {
  cat <<'EOF'
Usage: launch-codex-lane --worktree DIR --brief FILE --result FILE --run-log FILE [options]

Launch codex exec for one agent-fanout lane and fail fast if Codex never
emits child-bound progress, or later goes quiet for too long.

Required:
  --worktree DIR          Git worktree to run in
  --brief FILE            Prompt/brief file passed to codex exec
  --result FILE           Codex -o result file path
  --run-log FILE          Child stderr log path

Options:
  --startup-timeout SEC   Seconds to wait for first child progress (default: 600)
  --quiet-timeout SEC     Seconds of no child progress after startup (default: 600)
  --event-log FILE        Child codex --json stdout log (default: RUN_LOG.events.jsonl)
  --state-dir DIR         Persist machine-readable lane lifecycle and PID files
  --poll-interval SEC     Poll interval while waiting (default: 5)
  --codex-bin PATH        Codex executable (default: codex)
  --model MODEL           Add -m MODEL to codex exec
  --reasoning-effort E    Add -c model_reasoning_effort="E"
  --config KEY=VALUE      Add an extra -c KEY=VALUE; may be repeated
  --no-network            Do not add sandbox_workspace_write.network_access=true
  -h, --help              Show this help

Exit codes:
  0     codex completed successfully
  124   progress watchdog killed an alive-but-inactive codex process
  130   wrapper interrupted by a signal. Before progress confirmation the
        child is killed too; after "progress confirmed" the wrapper DETACHES
        and codex keeps running â€” adopt the pid it prints, not a lane failure
  other codex exit code, or 1 if codex exited cleanly without any progress signal
EOF
}

worktree=
brief=
result=
run_log=
event_log=
state_dir=
startup_timeout=600
quiet_timeout=600
poll_interval=5
codex_bin=codex
model=
reasoning_effort=
network_enabled=1
extra_configs=()

while (($#)); do
  case "$1" in
    --worktree)
      worktree=${2:-}; shift 2 ;;
    --brief)
      brief=${2:-}; shift 2 ;;
    --result)
      result=${2:-}; shift 2 ;;
    --run-log)
      run_log=${2:-}; shift 2 ;;
    --startup-timeout)
      startup_timeout=${2:-}; shift 2 ;;
    --quiet-timeout)
      quiet_timeout=${2:-}; shift 2 ;;
    --event-log)
      event_log=${2:-}; shift 2 ;;
    --state-dir)
      state_dir=${2:-}; shift 2 ;;
    --poll-interval)
      poll_interval=${2:-}; shift 2 ;;
    --codex-bin)
      codex_bin=${2:-}; shift 2 ;;
    --model)
      model=${2:-}; shift 2 ;;
    --reasoning-effort)
      reasoning_effort=${2:-}; shift 2 ;;
    --config)
      extra_configs+=("${2:-}"); shift 2 ;;
    --no-network)
      network_enabled=0; shift ;;
    -h|--help)
      usage; exit 0 ;;
    *)
      echo "launch-codex-lane: unknown argument: $1" >&2
      usage >&2
      exit 2 ;;
  esac
done

die() {
  echo "launch-codex-lane: $*" >&2
  exit 2
}

[[ -n "$worktree" ]] || die "--worktree is required"
[[ -n "$brief" ]] || die "--brief is required"
[[ -n "$result" ]] || die "--result is required"
[[ -n "$run_log" ]] || die "--run-log is required"
[[ "$startup_timeout" =~ ^[0-9]+$ ]] || die "--startup-timeout must be an integer"
[[ "$quiet_timeout" =~ ^[0-9]+$ ]] || die "--quiet-timeout must be an integer"
[[ "$poll_interval" =~ ^[0-9]+$ ]] || die "--poll-interval must be an integer"
(( startup_timeout > 0 )) || die "--startup-timeout must be positive"
(( quiet_timeout > 0 )) || die "--quiet-timeout must be positive"
(( poll_interval > 0 )) || die "--poll-interval must be positive"
[[ -d "$worktree" ]] || die "worktree does not exist: $worktree"
worktree=$(cd "$worktree" && pwd -P)
[[ -f "$brief" ]] || die "brief does not exist: $brief"
git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
  || die "not a git worktree: $worktree"
command -v "$codex_bin" >/dev/null 2>&1 || die "codex executable not found: $codex_bin"
command -v perl >/dev/null 2>&1 || die "perl is required to launch codex in its own process group"

if [[ -z "$event_log" ]]; then
  event_log=$run_log.events.jsonl
fi

mkdir -p "$(dirname "$result")" "$(dirname "$run_log")" "$(dirname "$event_log")"
rm -f "$result"
: > "$run_log"
: > "$event_log"

atomic_write() {
  local file=$1 value=$2 tmp
  tmp=$file.tmp.$$
  printf '%s\n' "$value" > "$tmp"
  mv "$tmp" "$file"
}

set_lane_status() {
  [[ -n "$state_dir" ]] || return 0
  atomic_write "$state_dir/status" "$1"
}

final_state_override=
if [[ -n "$state_dir" ]]; then
  mkdir -p "$state_dir"
  atomic_write "$state_dir/wrapper.pid" "$$"
  atomic_write "$state_dir/wrapper.start" "$(ps -o lstart= -p $$ | sed 's/^ *//;s/ *$//')"
  atomic_write "$state_dir/worktree" "$worktree"
  atomic_write "$state_dir/result" "$result"
  atomic_write "$state_dir/run-log" "$run_log"
  atomic_write "$state_dir/event-log" "$event_log"
  set_lane_status dispatching
fi

sentinel=$(mktemp "${TMPDIR:-/tmp}/agent-fanout-codex-start.XXXXXX")
cleanup_sentinel() {
  rm -f "$sentinel"
  rm -f "${LAUNCH_CODEX_LANE_SELFCOPY:-}"
}
on_exit() {
  local code=$?
  cleanup_sentinel
  if [[ -n "$state_dir" ]]; then
    atomic_write "$state_dir/exit-code" "$code"
    case "$final_state_override" in
      cancelled|interrupted|failed)
        set_lane_status "$final_state_override"
        ;;
      *)
        if (( code == 0 )); then
          set_lane_status succeeded
        else
          set_lane_status failed
        fi
        ;;
    esac
  fi
}
trap on_exit EXIT
touch "$sentinel"
# BSD find's -newer can effectively compare at coarse timestamp resolution in
# fast tests and launches. Backdate the sentinel slightly so a rollout created
# immediately after launch is still considered newer.
perl -e 'utime(time() - 2, time() - 2, @ARGV)' "$sentinel" 2>/dev/null || true

baseline_status=$(git -C "$worktree" status --porcelain --untracked-files=normal)
brief_text=$(<"$brief")

codex_args=(exec --json --sandbox workspace-write)
if (( network_enabled )); then
  codex_args+=(-c sandbox_workspace_write.network_access=true)
fi
codex_args+=(-c features.default_mode_request_user_input=false)
if [[ -n "$model" ]]; then
  codex_args+=(-m "$model")
fi
if [[ -n "$reasoning_effort" ]]; then
  codex_args+=(-c "model_reasoning_effort=\"$reasoning_effort\"")
fi
for cfg in "${extra_configs[@]}"; do
  [[ -n "$cfg" ]] || die "--config requires KEY=VALUE"
  codex_args+=(-c "$cfg")
done
codex_args+=(-o "$result" "$brief_text")

child_pid=
child_pgid=
progress_confirmed=0

kill_child_group() {
  if [[ -n "${child_pid:-}" ]] && kill -0 "$child_pid" 2>/dev/null; then
    # The perl shim set its process group id to its pid before execing codex.
    kill -TERM "-${child_pgid:-$child_pid}" 2>/dev/null || true
    sleep 2
    kill -KILL "-${child_pgid:-$child_pid}" 2>/dev/null || true
  fi
}

# Before progress is confirmed the wrapper owns the child: a signal kills it
# (a dead-start is not worth preserving). After confirmation the lane owns
# itself: a signal detaches so orchestrator impatience cannot destroy live work.
on_signal() {
  if [[ -n "$state_dir" ]]; then
    final_state_override=interrupted
    set_lane_status interrupting
    kill_child_group
    exit 130
  fi
  if (( progress_confirmed )); then
    {
      echo "agent-fanout: wrapper interrupted after progress; codex is still running"
      echo "agent-fanout: child pid=$child_pid worktree=$worktree"
      echo "agent-fanout: result=$result run_log=$run_log event_log=$event_log"
      echo "agent-fanout: adopt with: while kill -0 $child_pid 2>/dev/null; do sleep 20; done"
      echo "agent-fanout: kill the child only for user stop, destructive/out-of-scope writes, or an adopted-runner quiet wedge"
    } >&2
    exit 130
  fi
  kill_child_group
  exit 130
}
trap on_signal INT TERM HUP

on_force_cancel() {
  final_state_override=cancelled
  set_lane_status cancelling
  kill_child_group
  exit 125
}
trap on_force_cancel USR1

(
  cd "$worktree"
  exec perl -e 'setpgrp(0, 0) or die "setpgrp: $!"; exec @ARGV or die "exec: $!"' \
    "$codex_bin" "${codex_args[@]}"
) >"$event_log" 2>"$run_log" </dev/null &
child_pid=$!
child_pgid=$child_pid
if [[ -n "$state_dir" ]]; then
  atomic_write "$state_dir/child.pid" "$child_pid"
  atomic_write "$state_dir/child.pgid" "$child_pgid"
  atomic_write "$state_dir/child.start" "$(ps -o lstart= -p "$child_pid" | sed 's/^ *//;s/ *$//')"
  set_lane_status running
fi

echo "agent-fanout: launched codex pid=$child_pid worktree=$worktree"
echo "agent-fanout: startup timeout=${startup_timeout}s quiet timeout=${quiet_timeout}s run_log=$run_log event_log=$event_log result=$result"

rollout_files_for_worktree() {
  local sessions_dir=${CODEX_HOME:-$HOME/.codex}/sessions
  [[ -d "$sessions_dir" ]] || return 0
  find "$sessions_dir" -type f -name 'rollout-*.jsonl' -newer "$sentinel" -print 2>/dev/null \
    | while IFS= read -r file; do
        if command -v ruby >/dev/null 2>&1; then
          ruby -rjson -e '
            target = ARGV.shift
            file = ARGV.shift
            meta = File.foreach(file).find { |line| line.include?("\"session_meta\"") }
            exit 1 unless meta
            payload = JSON.parse(meta).fetch("payload", {})
            exit(payload["cwd"] == target && payload["originator"] == "codex_exec" ? 0 : 1)
          ' "$worktree" "$file" 2>/dev/null && printf '%s\n' "$file"
        else
          grep -Fq "\"cwd\":\"$worktree\"" "$file" 2>/dev/null \
            && grep -Fq '"originator":"codex_exec"' "$file" 2>/dev/null \
            && printf '%s\n' "$file"
        fi
      done
}

event_progress_count() {
  grep -Ec '"type"[[:space:]]*:[[:space:]]*"(turn\.started|turn\.completed|turn\.failed|error|item\.started|item\.completed)"|"_type"[[:space:]]*:[[:space:]]*"(turn\.started|turn\.completed|turn\.failed|error|item\.started|item\.completed)"' "$event_log" 2>/dev/null || true
}

file_size() {
  if [[ -e "$1" ]]; then
    wc -c < "$1" | tr -d '[:space:]'
  else
    printf 0
  fi
}

detect_progress_signal() {
  if [[ -s "$result" ]]; then
    printf 'result file created'
    return 0
  fi

  local events
  events=$(event_progress_count)
  if [[ "$events" =~ ^[0-9]+$ ]] && (( events > 0 )); then
    printf 'codex json progress (%s events)' "$events"
    return 0
  fi

  local current_status
  current_status=$(git -C "$worktree" status --porcelain --untracked-files=normal)
  if [[ "$current_status" != "$baseline_status" ]]; then
    printf 'worktree status changed'
    return 0
  fi

  return 1
}

write_diagnostic_result() {
  local reason=$1
  {
    echo "Codex lane progress watchdog failed."
    echo
    echo "Reason: $reason"
    echo "Worktree: $worktree"
    echo "Brief: $brief"
    echo "Run log: $run_log"
    echo "Event log: $event_log"
    echo "Startup timeout: ${startup_timeout}s"
    echo "Quiet timeout: ${quiet_timeout}s"
    echo "Child pid: ${child_pid:-unknown}"
    echo "Progress confirmed: $progress_confirmed"
    echo
    echo "Child Codex rollout files:"
    local any=0 file line_count
    while IFS= read -r file; do
      any=1
      line_count=$(wc -l < "$file" | tr -d '[:space:]')
      echo "- $file (${line_count} records)"
    done < <(rollout_files_for_worktree)
    if (( ! any )); then
      echo "- none found after launch"
    fi
    echo
    echo "Event log tail:"
    tail -80 "$event_log" 2>/dev/null || true
    echo
    echo "Git status delta:"
    local current_status
    current_status=$(git -C "$worktree" status --porcelain --untracked-files=normal)
    if [[ "$current_status" == "$baseline_status" ]]; then
      echo "(unchanged from launch)"
    else
      printf '%s\n' "$current_status"
    fi
    echo
    echo "Run log tail:"
    tail -80 "$run_log" 2>/dev/null || true
  } > "$result"
}

startup_deadline=$((SECONDS + startup_timeout))
last_progress_at=$SECONDS
last_progress_signal=
last_event_size=0
last_result_size=0
last_run_log_size=0
last_status=$baseline_status

record_progress() {
  last_progress_signal=$1
  last_progress_at=$SECONDS
  if (( ! progress_confirmed )); then
    progress_confirmed=1
    echo "agent-fanout: progress confirmed: $last_progress_signal"
    echo "agent-fanout: keep waiting for process exit; no diff yet is normal during analysis"
    echo "agent-fanout: interrupt only for user stop or out-of-scope/destructive writes; quiet wedges are supervised by the wrapper"
  fi
}

poll_progress() {
  local signal current_event_size current_result_size current_run_log_size current_status
  if signal=$(detect_progress_signal); then
    current_event_size=$(file_size "$event_log")
    current_result_size=$(file_size "$result")
    current_run_log_size=$(file_size "$run_log")
    current_status=$(git -C "$worktree" status --porcelain --untracked-files=normal)
    if [[ "$signal" != "$last_progress_signal" || "$current_event_size" != "$last_event_size" || "$current_result_size" != "$last_result_size" || "$current_run_log_size" != "$last_run_log_size" || "$current_status" != "$last_status" ]]; then
      last_event_size=$current_event_size
      last_result_size=$current_result_size
      last_run_log_size=$current_run_log_size
      last_status=$current_status
      record_progress "$signal"
    elif (( ! progress_confirmed )); then
      record_progress "$signal"
    fi
  fi
}

while kill -0 "$child_pid" 2>/dev/null; do
  poll_progress

  if (( ! progress_confirmed && SECONDS >= startup_deadline )); then
    echo "agent-fanout: startup progress watchdog timed out; killing codex process group" >&2
    write_diagnostic_result "no child progress before startup timeout: no codex --json progress event, no result file, and no worktree diff"
    kill_child_group
    wait "$child_pid" 2>/dev/null || true
    final_state_override=failed
    exit 124
  fi

  if (( progress_confirmed && SECONDS - last_progress_at >= quiet_timeout )); then
    echo "agent-fanout: quiet progress watchdog timed out; killing codex process group" >&2
    write_diagnostic_result "no child progress for ${quiet_timeout}s after: ${last_progress_signal:-unknown}"
    kill_child_group
    wait "$child_pid" 2>/dev/null || true
    final_state_override=failed
    exit 124
  fi

  sleep "$poll_interval"
done

set +e
wait "$child_pid"
child_status=$?
set -e

poll_progress
if (( ! progress_confirmed )); then
  if signal=$(detect_progress_signal); then
    record_progress "$signal at process exit"
  else
    write_diagnostic_result "codex exited before any child progress signal (exit $child_status)"
    if (( child_status == 0 )); then
      exit 1
    fi
  fi
fi
exit "$child_status"
